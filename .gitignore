# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/

# ── Large raw data files ───────────────────────────────────────────────────────
# Download via code/phase1_QC/01_data_acquisition.sh or Allen Brain Cell Atlas
*.h5ad
*.loom
*.h5
*.feather

# ── MD simulation trajectories and restart files ──────────────────────────────
# Fully reproducible from GROMACS input files (.mdp, .gro, .top) on TRUBA
*.xtc
*.trr
*.edr
*.cpt
*.tpr
*.gro

# ── Sparse matrix intermediates ───────────────────────────────────────────────
# Generated by scMultiomeGRN; reconstructable from h5ad
results/phase2/scMultiomeGRN/input/*/scrna/matrix.mtx
results/phase2/scMultiomeGRN/input/*/scrna/barcodes.tsv
results/phase2/scMultiomeGRN/input/*/scrna/features.tsv
results/phase2/scMultiomeGRN/input/*/atac/matrix.mtx
results/phase2/scMultiomeGRN/input/*/atac/barcodes.tsv
results/phase2/scMultiomeGRN/input/*/atac/features.tsv

# ── CellOracle fitted object ──────────────────────────────────────────────────
*.celloracle.oracle
results/phase5/celloracle/adata_prepared.h5ad

# ── CellChat R object ─────────────────────────────────────────────────────────
*.rds

# ── Docking pose files ────────────────────────────────────────────────────────
# Thousands of binary outputs; summary CSVs in the same folders are kept
*.pdbqt
results/phase4/vina/*/
results/phase4/vina_tier2/*.pdbqt

# ── MMPBSA per-complex run directories — exclude everything except summary CSV
# Summary at results/phase4/mmpbsa/mmpbsa_summary.csv is kept
results/phase4/mmpbsa/*/
results/phase4/mmpbsa_tier2/*/

# ── MD run directories — exclude all per-complex subdirectories ───────────────
# Summary CSVs at results/phase4/ level are kept; .xvg time-series are committed
results/phase4/md/*/
!results/phase4/md/**/*.xvg

# ── fpocket raw per-pocket outputs — keep only summary files ─────────────────
# Summary CSVs (e.g. pocket_info.csv) are kept; per-pocket .pqr/.pdb excluded
results/phase3/fpocket/**/*_out/
results/phase3/fpocket/**/*.pqr

# ── Large GRN adjacency matrices (per-seed; aggregated CSV kept) ──────────────
results/phase2/GRN/adj_matrix_seed*.tsv
results/phase2/GRN/adj_matrix.tsv
results/phase2/GRN/adj_matrix_aggregated.tsv

# ── Large ATAC intermediate files ─────────────────────────────────────────────
results/phase2/ATAC_validation/pseudobulk_microglia.csv
results/phase2/ATAC_validation/da_peaks.csv

# ── Motif database binaries ───────────────────────────────────────────────────
data/resources/motifs/*.tbl

# ── Raw data archives ─────────────────────────────────────────────────────────
data/raw/Mayo/
truba_docs/

# ── Literature PDFs (copyright) ───────────────────────────────────────────────
literature/seed_papers/*.pdf

# ── Stray / scratch files ─────────────────────────────────────────────────────
foo.txt
logs/

# ── Manuscript and peer review — not ready for public repo ───────────────────
results/manuscript/
peer_review/
journals/
CLAUDE.md
DAM-DRUG_Layman_Summary.md

# ── Project planning docs (not for public repo) ───────────────────────────────
rough_idea.txt
next_steps.txt
DAM-DRUG_Research_Plan.md
DAM-DRUG_Progress_Tracker.md
DAM-DRUG_Literature_Review_Protocol.md
system_prompt_lit_review.md
system_prompt_research_architect.md
methods_deviations.md
